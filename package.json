{
  "name": "basemsg",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@basemsg/mobile",
    "mobile:android": "npm run android --workspace=@basemsg/mobile",
    "mobile:ios": "npm run ios --workspace=@basemsg/mobile",
    "mobile:web": "npm run web --workspace=@basemsg/mobile",
    "mobile:lint": "npm run lint --workspace=@basemsg/mobile",
    "web": "npm run start --workspace=@basemsg/web",
    "backend": "npm run start --workspace=@basemsg/backend"
  },
  "dependencies": {
    "http-proxy-middleware": "^3.0.5"
  }
}
